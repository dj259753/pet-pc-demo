{
  "name": "qq-pet-installer",
  "version": "0.3.1",
  "description": "QQ宠物 安装引导向导",
  "main": "main.js",
  "author": "Jerry",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.jerry.qq-pet-installer",
    "productName": "QQ宠物",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "title": "QQ宠物 安装程序",
      "window": {
        "width": 540,
        "height": 460
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "extraResources": [
      {
        "from": "../agents",
        "to": "agents"
      },
      {
        "from": "../bundle/pc-pet-demo",
        "to": "pc-pet-demo",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!dist/**",
          "!.git/**"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.0.0"
  }
}
