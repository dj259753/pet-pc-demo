{
  "name": "qq-pet-skills",
  "version": "0.1.1",
  "description": "QQ宠物Skills版 - 基于 OpenClaw 多Agent架构的桌面宠物",
  "main": "electron/main.js",
  "author": "Jerry",
  "license": "MIT",
  "scripts": {
    "start": "npx electron .",
    "build": "npx electron-builder --mac",
    "release:summary": "node scripts/release-note-helper.js",
    "release:summary:from-root": "node scripts/release-note-helper.js --from-root"
  },
  "build": {
    "appId": "com.jerry.qq-pet-skills",
    "productName": "QQ宠物Skills版",
    "mac": {
      "target": "dir",
      "category": "public.app-category.entertainment"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "assets/**/*",
      "openclaw-skill/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "node-fetch": "^2.7.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  }
}
